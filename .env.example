# Supabase Configuration
# Copy this file to .env.local and fill in your values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_ANNUAL=price_your-annual-price-id

# Anthropic (vision AI image classification)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# MapTiler (browse page map)
# Free tier: 100K tile loads/month — https://cloud.maptiler.com/account/keys/
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-api-key

# Deepgram (voice input fallback for Firefox/iOS Safari)
# $200 free credit for new accounts — https://console.deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-api-key

# Google Places API (review snippets on provider pages)
# Restricted to Places API (New) only — $5/1K requests
# Project: Olera Provider API (olera-provider-api)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Perplexity API (AI trust signal verification for non-CMS providers)
# ~$1 per 1,000 providers — https://docs.perplexity.ai/
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key

# Slack Integration (verification alerts and admin actions)
# Webhook URL: https://api.slack.com/apps/YOUR_APP/incoming-webhooks
# Signing Secret: https://api.slack.com/apps/YOUR_APP/general (Basic Information)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/WORKSPACE/CHANNEL/SECRET
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Smartlead (tier-2 cold MedJobs outreach — lib/smartlead.ts)
# API key: Smartlead → Settings → API. Until this is set, the outbound engine
# is a no-op (every call returns { ok: false }). Cold sending only; tier-1
# transactional mail stays on Resend/olera.care.
SMARTLEAD_API_KEY=your-smartlead-api-key
# Optional base-URL override; defaults to https://server.smartlead.ai/api/v1
# SMARTLEAD_BASE_URL=
